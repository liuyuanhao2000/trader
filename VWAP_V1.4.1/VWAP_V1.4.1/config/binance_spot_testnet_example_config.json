{
  "instrument_type": "spot",
  "contract_type": "USDT_perpetual",
  "exchange": {
    "adapter": "binance_spot_testnet",
    "binance_base_url": "https://testnet.binance.vision",
    "limit_order_poll_seconds": 1.5,
    "balance_cache_ttl_seconds": 5
  },
  "common": {
    "symbol": "BTCUSDT",
    "side": "BUY",
    "notional": 1000,
    "start_time": "2026-04-02T15:30:00",
    "quote_currency": "USDT",
    "base_currency": "BTC"
  },
  "execution": {
    "total_duration_seconds": 600,
    "order_interval_seconds": 60,
    "price_offset": 0.0002,
    "price_offset_mode": "relative",
    "max_slippage": 0.01,
    "unfilled_alarm_threshold": 0.1,
    "record_granularity": "per_order",
    "tail_force_early_seconds": 0,
    "tail_risk_threshold_ratio": 0.1,
    "tail_market_slippage": 0.002,
    "spot_sell_truncate_to_holdings": true,
    "leverage": 5,
    "contract_multiplier": 1.0,
    "mock_fill_sensitivity": 0.15,
    "debug": false
  },
  "log_storage": {
    "output_jsonl_path": "execution_logs.jsonl"
  },
  "alerting": {
    "print_alerts": true
  }
}

